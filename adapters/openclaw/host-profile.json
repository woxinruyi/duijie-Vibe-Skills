{
  "adapter_id": "openclaw",
  "host_name": "OpenClaw",
  "status": "preview",
  "runtime_role": "official-runtime-adapter",
  "source_evidence": [
    "config/runtime-core-packaging.json",
    "adapters/openclaw/closure.json",
    "install.sh",
    "check.sh"
  ],
  "settings_surface": {
    "path": "~/.openclaw",
    "managed_by_repo": true,
    "notes": "The repository can materialize runtime-core payload into the documented OpenClaw host root, while host login, model access, and editor-specific projection remain host-managed."
  },
  "discoverable_entries": {
    "shared_source": "config/vibe-entry-surfaces.json",
    "authority_owner": "vibe",
    "presentational_only": true,
    "notes": "Discoverable Vibe entries are host-facing launch labels only and do not create a second runtime authority."
  },
  "host_managed_surfaces": [
    "login and account state",
    "model permissions and BYOK boundaries",
    "plugin provisioning",
    "provider credentials",
    "workspace projection and editor-specific settings"
  ],
  "capabilities": {
    "fs.read": "expected",
    "fs.write": "expected",
    "shell.exec": "expected",
    "mcp.client": "supported-with-constraints",
    "settings.materialize": "runtime-core",
    "plugin.provision": "host-managed",
    "agent.spawn": "expected",
    "route.provider_call": "host-managed",
    "route.offline_fallback": "host-managed",
    "release.verify": "runtime-core"
  },
  "degrade_contract": {
    "runtime_core_only_install": "degraded-but-supported",
    "host_login_or_model_access_missing": "host-managed",
    "workspace_projection_not_installed": "degraded-but-supported"
  },
  "supported_platform_contracts": [
    "adapters/openclaw/platform-windows.json",
    "adapters/openclaw/platform-linux.json",
    "adapters/openclaw/platform-macos.json"
  ]
}
