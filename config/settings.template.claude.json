{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "<YOUR_API_KEY>",
    "ANTHROPIC_BASE_URL": "<YOUR_API_BASE_URL>",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": true,
    "VCO_INTENT_ADVICE_API_KEY": "<USER_PROVIDED_INTENT_ADVICE_API_KEY>",
    "VCO_INTENT_ADVICE_BASE_URL": "<USER_PROVIDED_INTENT_ADVICE_BASE_URL>",
    "VCO_INTENT_ADVICE_MODEL": "<USER_PROVIDED_INTENT_ADVICE_MODEL>",
    "VCO_VECTOR_DIFF_API_KEY": "<USER_PROVIDED_VECTOR_DIFF_API_KEY>",
    "VCO_VECTOR_DIFF_BASE_URL": "<USER_PROVIDED_VECTOR_DIFF_BASE_URL>",
    "VCO_VECTOR_DIFF_MODEL": "<USER_PROVIDED_VECTOR_DIFF_MODEL>"
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "model": "opus",
  "enabledPlugins": {
    "hookify@claude-plugins-official": true,
    "claude-code-settings@claude-code-settings": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "feature-dev@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true
  },
  "skipDangerousModePermissionPrompt": true
}
